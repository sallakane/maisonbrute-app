# ==========================================================================
#  .env.local — secrets & configuration PROD (VPS). À copier en .env.local et
#  compléter. NE PAS COMMITER. chmod 600 (il contient les clés Stripe).
# ==========================================================================

APP_ENV=prod
APP_DEBUG=0

# Générer : php -r 'echo bin2hex(random_bytes(16)), "\n";'
APP_SECRET=CHANGEME_32_hex

# --- Base de données ---
# POSTGRES_PASSWORD n'est lu qu'à l'INITIALISATION du volume Postgres : le définir
# maintenant. Le modifier après le 1er démarrage n'a plus d'effet (passer par SQL).
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGEME_mot_de_passe_fort
# L'hôte est le service `database` du compose ; le mot de passe doit être IDENTIQUE.
DATABASE_URL="postgresql://app:CHANGEME_mot_de_passe_fort@database:5432/app?serverVersion=16&charset=utf8"

# --- Réseau / VPS mutualisé ---
# Vérifier le port AVANT (ss -tlnp | grep 127.0.0.1:80). 8084 = réservé Maison Brute.
APP_HTTP_PORT=8084
# URL publique — sert à générer les liens HORS contexte HTTP (worker → e-mails).
# Sans elle (défaut http://localhost), les liens des e-mails clients sont morts.
DEFAULT_URI=https://maisonbrute.fr

# --- Stripe (⚠️ commencer en TEST ; passer en live seulement au lancement) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLIC_KEY=pk_test_xxx
# Secret de signature du webhook (dashboard Stripe → endpoint https://maisonbrute.fr/webhook/stripe)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- E-mails transactionnels (Brevo/Mailgun/Postmark…) ---
# ⚠️ Absent ⇒ le défaut null://null s'applique : AUCUN e-mail, sans la moindre erreur.
MAILER_DSN=smtp://user:pass@smtp.exemple.com:587
MAIL_FROM="Maison Brute <convoyage@maisonbrute.fr>"

# --- Messenger (transport async doctrine, déjà par défaut) ---
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
