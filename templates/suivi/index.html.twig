{% extends 'storefront/layout.html.twig' %}

{% block title %}Suivi de commande — Maison Brute{% endblock %}

{% block storefront %}
  <section style="padding:56px 56px 40px;border-bottom:1px solid rgba(20,20,22,.16);display:flex;justify-content:space-between;align-items:flex-end;gap:40px;flex-wrap:wrap">
    <div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.3em;text-transform:uppercase;color:#6E6F6A;margin-bottom:18px;display:flex;align-items:center;gap:12px"><span style="width:7px;height:7px;background:#7E8C82;display:inline-block"></span>Suivi de commande</div>
      <h1 style="margin:0;font-family:'Archivo',sans-serif;font-weight:800;font-size:56px;line-height:.94;letter-spacing:-.035em;text-transform:uppercase;color:#141416">Où en est mon colis ?</h1>
    </div>
    {% if order %}
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#6E6F6A;text-align:right;line-height:1.9">Commande N° {{ order.reference }}<br>Passée le {{ order.createdAt|date('d/m/Y') }}<br>Jour d'attente : <span style="color:#141416">{{ order.joursAttente }}</span></div>
    {% endif %}
  </section>

  {% if not order %}
    <section style="padding:56px;max-width:560px">
      <p style="margin:0 0 28px;font-size:17px;line-height:1.65;color:#3B3C3D">Renseignez votre référence de commande et l'e-mail associé. Nous vous dirons précisément où votre colis n'est pas.</p>
      <form method="post" action="{{ path('app_suivi') }}" style="display:flex;flex-direction:column;gap:18px">
        <input type="hidden" name="_token" value="{{ csrf_token('suivi') }}">
        <div>
          <label style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#6E6F6A;margin-bottom:8px;display:block">Référence (MB-…)</label>
          <input name="reference" value="{{ reference }}" required placeholder="MB-XXXXXX" style="width:100%;border:1px solid rgba(20,20,22,.3);background:#EFEFEB;padding:14px 15px;font-family:'IBM Plex Mono',monospace;font-size:13px">
        </div>
        <div>
          <label style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#6E6F6A;margin-bottom:8px;display:block">E-mail de la commande</label>
          <input name="email" type="email" required placeholder="vous@exemple.fr" style="width:100%;border:1px solid rgba(20,20,22,.3);background:#EFEFEB;padding:14px 15px;font-family:'IBM Plex Mono',monospace;font-size:13px">
        </div>
        <button type="submit" style="align-self:flex-start;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:#E8E8E3;background:#141416;padding:16px 30px;border:1px solid #141416;cursor:pointer">Consulter le convoyage</button>
      </form>
    </section>
  {% else %}
    <section style="display:grid;grid-template-columns:1.1fr 1fr;gap:0;border-bottom:1px solid rgba(20,20,22,.16)">
      <div style="padding:56px;border-right:1px solid rgba(20,20,22,.16)">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:15px;line-height:1.9;background:#EFEFEB;border:1px solid #141416;padding:36px 38px;color:#141416;box-shadow:8px 8px 0 rgba(126,140,130,.28)">
          <div style="display:flex;justify-content:space-between;font-weight:500;letter-spacing:.06em;font-size:14px"><span>BON DE CONVOYAGE</span><span>N° {{ order.reference }}</span></div>
          <div style="border-top:1px dashed #6E6F6A;margin:16px 0 20px"></div>
          <div style="margin-bottom:14px;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#6E6F6A">Statut actuel</div>
          <div style="font-size:20px;line-height:1.4;color:#141416;min-height:56px">{{ order.dernierEvent ? order.dernierEvent.libelle|lower : 'en attente de prise en charge.' }}</div>
          <div style="border-top:1px dashed #6E6F6A;margin:22px 0 18px"></div>
          <div style="margin-bottom:8px">Transporteur : <span style="color:#7E8C82">{{ order.transporteur }}</span></div>
          <div style="margin-bottom:8px">Prochaine mise à jour : <span style="color:#7E8C82">indéterminée.</span></div>
          <div>Empreinte carbone du trajet : en cours de calcul depuis {{ order.joursAttente }} jour{{ order.joursAttente > 1 ? 's' : '' }}.</div>
        </div>
        <form method="post" action="{{ path('app_suivi') }}" style="display:flex;gap:14px;margin-top:26px">
          <input type="hidden" name="_token" value="{{ csrf_token('suivi') }}">
          <input type="hidden" name="reference" value="{{ order.reference }}">
          <input type="hidden" name="email" value="{{ order.email }}">
          <button type="submit" style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:#E8E8E3;background:#141416;padding:16px 28px;border:1px solid #141416;cursor:pointer">Actualiser le statut</button>
        </form>
        <p style="margin:18px 0 0;font-family:'IBM Plex Mono',monospace;font-size:11px;line-height:1.6;color:#6E6F6A">Actualiser ne rapproche pas le colis. Cela vous rapproche, en revanche, d'une certaine forme d'acceptation.</p>
      </div>

      <div style="position:relative;min-height:520px;background:repeating-linear-gradient(45deg,#CBCBC5 0 18px,#C2C2BC 18px 36px);display:flex;align-items:center;justify-content:center">
        <div style="position:absolute;top:20px;left:20px;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;background:#141416;color:#E8E8E3;padding:6px 12px">Position dans l'univers</div>
        <div class="mb-pulse" style="width:16px;height:16px;background:#7E8C82;border:2px solid #141416;border-radius:50%"></div>
        <span style="position:absolute;bottom:22px;left:0;right:0;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#8A8B84">Carte de convoyage — visuel à intégrer</span>
      </div>
    </section>

    <section style="padding:72px 56px 96px">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#6E6F6A;margin-bottom:36px;display:flex;align-items:center;gap:10px"><span style="width:7px;height:7px;background:#7E8C82;display:inline-block"></span>Historique du convoyage</div>
      <div style="max-width:820px">
        <div style="display:grid;grid-template-columns:200px 1fr;border-left:1px solid rgba(20,20,22,.2)">
          {% for event in order.trackingEvents %}
            {% set dernier = loop.last %}
            <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:{{ dernier ? '#7E8C82' : '#6E6F6A' }};padding:0 0 32px 24px;position:relative"><span style="position:absolute;left:-5px;top:2px;width:9px;height:9px;background:{{ dernier ? '#7E8C82' : '#141416' }};border-radius:50%"{% if dernier %} class="mb-pulse"{% endif %}></span>{{ event.createdAt|date('d/m/Y H:i') }}</div>
            <div style="padding:0 0 32px 24px"><div style="font-size:15px;color:{{ dernier ? '#7E8C82' : '#141416' }}">{{ event.libelle }}</div>{% if dernier %}<div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#6E6F6A;margin-top:6px">Prochaine étape : indéterminée</div>{% endif %}</div>
          {% else %}
            <div style="padding:0 0 32px 24px;grid-column:1/3;font-size:15px;color:#6E6F6A">Aucun événement pour l'instant. Le colis rassemble ses esprits.</div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}
{% endblock %}

{% block head_extra %}
  <style>
    @keyframes mbPulse { 0%,100% { opacity:1 } 50% { opacity:.35 } }
    .mb-pulse { animation: mbPulse 2s ease-in-out infinite }
    @media (prefers-reduced-motion: reduce) { .mb-pulse { animation: none } }
  </style>
{% endblock %}
