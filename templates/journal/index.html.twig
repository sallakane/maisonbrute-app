{% extends 'storefront/layout.html.twig' %}

{% set seo_description = 'Le Journal de la Maison Brute : réflexions sur le luxe, la lenteur et l’art de désirer sans jamais recevoir.' %}
{% set canonical = url('app_journal') %}

{% block title %}Le Journal — Maison Brute{% endblock %}

{% block storefront %}
  <section style="padding:64px 56px 48px;text-align:center;border-bottom:1px solid rgba(20,20,22,.16)">
    <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#6E6F6A;margin-bottom:20px">Le Journal — Maison Brute</div>
    <h1 style="margin:0;font-family:'Playfair Display',serif;font-style:italic;font-weight:400;font-size:72px;line-height:1;letter-spacing:-.01em;color:#141416">Le&nbsp;Journal</h1>
    <p style="margin:20px auto 0;max-width:560px;font-size:16px;line-height:1.65;color:#3B3C3D;text-wrap:pretty">Réflexions sur le luxe, la lenteur et l'art de désirer sans jamais recevoir.</p>
  </section>

  {% if une %}
    <a href="{{ path('app_journal_article', { slug: une.slug }) }}" style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid rgba(20,20,22,.16)">
      <div style="min-height:460px;background:repeating-linear-gradient(45deg,#CFCFC9 0 16px,#C6C6C0 16px 32px);border-right:1px solid rgba(20,20,22,.16);position:relative"><span style="position:absolute;bottom:20px;left:20px;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#8A8B84">Visuel à intégrer</span></div>
      <div style="padding:64px 56px;display:flex;flex-direction:column;justify-content:center;background:#E1E5E0">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#6E6F6A;margin-bottom:20px">À la une · {{ une.rubrique }} · {{ une.tempsLecture }} min</div>
        <h2 style="margin:0 0 20px;font-family:'Playfair Display',serif;font-style:italic;font-weight:400;font-size:46px;line-height:1.08;color:#141416">{{ une.titre }}</h2>
        <p style="margin:0 0 24px;max-width:460px;font-size:17px;line-height:1.65;color:#2C2D2E;text-wrap:pretty">{{ une.chapo }}</p>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#141416;border-bottom:1px solid #141416;padding-bottom:3px;align-self:flex-start">Lire l'article →</span>
      </div>
    </a>
  {% endif %}

  <section style="padding:72px 56px 96px">
    {% if articles is empty and not une %}
      <p style="font-size:16px;color:#3B3C3D">Aucun article paru pour l'instant. La rédaction prend son temps — c'est la maison qui veut ça.</p>
    {% else %}
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:48px 40px">
        {% for article in articles %}
          <a href="{{ path('app_journal_article', { slug: article.slug }) }}" style="display:flex;flex-direction:column;gap:18px">
            <div style="aspect-ratio:16/11;border:1px solid rgba(20,20,22,.24);background:repeating-linear-gradient(45deg,#CFCFC9 0 14px,#C6C6C0 14px 28px)"></div>
            <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#6E6F6A">{{ article.rubrique }} · {{ article.tempsLecture }} min</div>
            <h3 style="margin:0;font-family:'Playfair Display',serif;font-style:italic;font-weight:400;font-size:28px;line-height:1.12;color:#141416">{{ article.titre }}</h3>
            <p style="margin:0;font-size:15px;line-height:1.6;color:#3B3C3D;text-wrap:pretty">{{ article.chapo }}</p>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </section>
{% endblock %}
