{% extends 'storefront/layout.html.twig' %}

{% block title %}Votre panier — Maison Brute{% endblock %}

{% block storefront %}
  <section style="padding:56px 56px 40px;border-bottom:1px solid rgba(20,20,22,.16)">
    <h1 style="margin:0 0 12px;font-family:'Archivo',sans-serif;font-weight:800;font-size:56px;line-height:.94;letter-spacing:-.035em;text-transform:uppercase;color:#141416">Votre panier</h1>
    <p style="margin:0;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:#6E6F6A">{{ items|length }} acquisition{{ items|length > 1 ? 's' : '' }} · 0 en cours d'acheminement effectif</p>
  </section>

  {% if items is empty %}
    <section style="padding:80px 56px 96px">
      <p style="font-size:17px;color:#3B3C3D">Votre panier est vide. Rien ne vous attend — mais rien ne vous fera attendre non plus.</p>
      <a href="{{ path('app_collections') }}" style="display:inline-block;margin-top:24px;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase">← Parcourir les collections</a>
    </section>
  {% else %}
    <section style="display:grid;grid-template-columns:1fr 400px;gap:56px;padding:48px 56px 96px;align-items:start">
      <div>
        {% for item in items %}
          {% set p = item.product %}
          <div style="display:flex;gap:24px;padding:28px 0;border-bottom:1px solid rgba(20,20,22,.16)">
            <div style="width:120px;height:150px;flex-shrink:0;position:relative;overflow:hidden;border:1px solid rgba(20,20,22,.24);background:repeating-linear-gradient(45deg,#CFCFC9 0 12px,#C6C6C0 12px 24px)">
              {% if p.imagePrincipale %}<img src="{{ p.imagePrincipale.chemin }}" alt="{{ p.nom }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover">{% endif %}
            </div>
            <div style="flex:1;display:flex;flex-direction:column">
              <div style="display:flex;justify-content:space-between;gap:20px">
                <div>
                  <h3 style="margin:0 0 6px;font-family:'Archivo',sans-serif;font-weight:600;font-size:20px;letter-spacing:-.01em"><a href="{{ path('app_product', { slug: p.slug }) }}" style="color:#141416">{{ p.nom }}</a></h3>
                  <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:#6E6F6A">Réf. {{ p.sku }}</div>
                </div>
                <div style="font-family:'IBM Plex Mono',monospace;font-size:16px;white-space:nowrap">{{ (item.ligneCents / 100)|number_format(0, ',', ' ') }}&nbsp;€</div>
              </div>
              <div style="margin-top:auto;display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap">
                <form method="post" action="{{ path('app_cart_update', { id: p.id }) }}" style="display:inline-flex;align-items:center;gap:10px;font-family:'IBM Plex Mono',monospace;font-size:13px">
                  <input type="hidden" name="_token" value="{{ csrf_token('cart_update' ~ p.id) }}">
                  <label style="color:#6E6F6A">Qté</label>
                  <input type="number" name="qty" value="{{ item.qty }}" min="0" style="width:64px;padding:8px;border:1px solid #141416;font-family:'IBM Plex Mono',monospace;background:#E8E8E3">
                  <button type="submit" style="padding:8px 12px;border:1px solid #141416;background:transparent;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase">OK</button>
                </form>
                <form method="post" action="{{ path('app_cart_remove', { id: p.id }) }}">
                  <input type="hidden" name="_token" value="{{ csrf_token('cart_remove' ~ p.id) }}">
                  <button type="submit" style="border:none;background:none;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#6E6F6A">Retirer</button>
                </form>
              </div>
            </div>
          </div>
        {% endfor %}
        <a href="{{ path('app_collections') }}" style="display:inline-block;margin-top:28px;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase">← Poursuivre la contemplation</a>
      </div>

      <aside style="border:1px solid #141416;padding:34px 32px">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#6E6F6A;margin-bottom:24px">Récapitulatif</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#141416">
          <div style="display:flex;justify-content:space-between;padding:10px 0"><span style="color:#6E6F6A">Sous-total</span><span>{{ (total_cents / 100)|number_format(0, ',', ' ') }}&nbsp;€</span></div>
          <div style="display:flex;justify-content:space-between;padding:10px 0"><span style="color:#6E6F6A">Livraison</span><span style="color:#7E8C82">gratuite, indéfiniment</span></div>
          <div style="display:flex;justify-content:space-between;padding:10px 0"><span style="color:#6E6F6A">Compensation carbone</span><span>impossible</span></div>
          <div style="border-top:1px solid rgba(20,20,22,.2);margin:16px 0 0;padding-top:18px;display:flex;justify-content:space-between;font-size:16px;font-weight:500"><span>Total</span><span>{{ (total_cents / 100)|number_format(0, ',', ' ') }}&nbsp;€</span></div>
        </div>
        <a href="{{ path('app_checkout') }}" style="display:block;text-align:center;margin-top:28px;font-family:'IBM Plex Mono',monospace;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:#E8E8E3;background:#141416;padding:20px;border:1px solid #141416">Passer à la commande</a>
        <p style="margin:18px 0 0;font-family:'IBM Plex Mono',monospace;font-size:11px;line-height:1.6;color:#6E6F6A;text-align:center">Paiement immédiat (en test). Livraison soumise aux limites physiques de la planète.</p>
      </aside>
    </section>
  {% endif %}
{% endblock %}
