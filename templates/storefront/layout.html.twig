{% extends 'base.html.twig' %}

{# Chaque page vitrine peut définir : seo_title, seo_description, canonical, og (block) #}

{% block head_meta %}
    {% if seo_description is defined and seo_description %}
        <meta name="description" content="{{ seo_description }}">
    {% endif %}
    {% if canonical is defined and canonical %}
        <link rel="canonical" href="{{ canonical }}">
    {% endif %}
    <meta property="og:site_name" content="Maison Brute">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{{ block('title') }}">
    {% if seo_description is defined and seo_description %}
        <meta property="og:description" content="{{ seo_description }}">
    {% endif %}
    {% if canonical is defined and canonical %}
        <meta property="og:url" content="{{ canonical }}">
    {% endif %}
    <meta property="og:image" content="{{ og_image is defined and og_image ? og_image : absolute_url(asset('images/og-default.svg')) }}">
    <meta name="twitter:card" content="summary_large_image">
    {% block head_extra %}{% endblock %}
{% endblock %}

{% block body %}
    <div style="position:relative;overflow:hidden">
        <twig:Nav />
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div role="status" style="padding:14px 56px;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.06em;background:{{ type == 'error' ? '#141416' : '#E1E5E0' }};color:{{ type == 'error' ? '#E8E8E3' : '#141416' }};border-bottom:1px solid rgba(20,20,22,.16)">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {% block storefront %}{% endblock %}
        <twig:Footer />
    </div>

    <div data-controller="cookie-banner" role="region" aria-label="Information cookies"
         style="position:fixed;left:0;right:0;bottom:0;z-index:50;background:#141416;color:#E8E8E3;padding:16px 24px;display:flex;align-items:center;justify-content:center;gap:20px;flex-wrap:wrap;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.04em">
        <span style="max-width:820px">Nous n'utilisons que des cookies <strong>essentiels</strong> (session, anti-CSRF). Ni traceur, ni publicité. Ils disparaîtront bien avant votre colis. <a href="{{ path('app_confidentialite') }}" style="color:#7E8C82;border-bottom:1px solid #7E8C82">En savoir plus</a></span>
        <button type="button" data-action="cookie-banner#dismiss" style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#141416;background:#E8E8E3;padding:12px 22px;border:1px solid #E8E8E3;cursor:pointer;white-space:nowrap">J'ai compris</button>
    </div>
{% endblock %}
